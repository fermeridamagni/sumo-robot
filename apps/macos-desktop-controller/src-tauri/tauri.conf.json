{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Magni Sumo Controller",
  "version": "0.1.0",
  "identifier": "dev.magni.sumo-controller",
  "build": {
    "beforeDevCommand": "bun run vite:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run vite:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Magni — Sumo Controller",
        "maximizable": true,
        "resizable": true,
        "fullscreen": true,
        "maximized": true,
        "minWidth": 900,
        "minHeight": 600,
        "url": "src/screens/main/index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
